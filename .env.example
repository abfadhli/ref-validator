# Required
ANTHROPIC_API_KEY=sk-ant-...

# Optional: email for Unpaywall/CrossRef polite pool
UNPAYWALL_EMAIL=your@email.com

# Optional: Semantic Scholar API key for higher rate limits
SEMANTIC_SCHOLAR_API_KEY=

# Optional: override default models
EXTRACTION_MODEL=claude-sonnet-4-6
VERIFICATION_MODEL=claude-sonnet-4-6

# API source toggles (true/false)
USE_CROSSREF=true
USE_SEMANTIC_SCHOLAR=true
USE_OPENALEX=true
USE_GOOGLE_SCHOLAR=false
USE_ARXIV=true

# Optional: directory containing PDFs of cited papers for level 3 verification
REFS_DIR=
